# ============================================================
# wechat-article-writer 配置文件模板
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写你的实际凭证
# 3. 运行 ./scripts/init-check.sh 验证配置
# ============================================================

# ============================================================
# 微信公众号凭证（必需）
# ============================================================
# 获取方式：
# 1. 登录 https://mp.weixin.qq.com
# 2. 左侧菜单 → 开发 → 基本配置
# 3. 获取 AppID 和 AppSecret
# -----------------------------------------------------------

WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# ============================================================
# IMA 笔记凭证（可选）
# ============================================================
# 获取方式：
# 1. 访问 https://ima.qq.com/agent-interface
# 2. 获取 Client ID 和 API Key
# 3. 填写到下方
# 
# 如果不配置，文章将不会自动保存到 IMA 笔记
# -----------------------------------------------------------

IMA_OPENAPI_CLIENTID=your_client_id_here
IMA_OPENAPI_APIKEY=your_api_key_here

# ============================================================
# 高级配置（可选，一般不需要修改）
# ============================================================

# 封面图默认尺寸
COVER_WIDTH=1280
COVER_HEIGHT=720

# 内容配图默认尺寸
CONTENT_IMG_WIDTH=900
CONTENT_IMG_HEIGHT=500

# 默认作者名
DEFAULT_AUTHOR=萧十一说

# ============================================================
# 配置验证
# ============================================================
# 保存后运行：./scripts/init-check.sh
# 确认所有检查项通过后再开始使用
# ============================================================
